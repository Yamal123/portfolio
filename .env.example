# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://yumeng.dev
NEXT_PUBLIC_SITE_NAME=PM 思钱想厚

# Admin Authentication
# Change these in production! Defaults only for local dev.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2026
ADMIN_JWT_SECRET=aipmym_jwt_secret_key_2026

# Agent Layer
# rules = 规则+工具模式（无需 API Key）
# llm   = 强制 LLM（无 Key 时回退 rules）
# auto  = 有 OPENAI_API_KEY 时用 LLM，否则 rules（默认）
AGENT_MODE=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AGENT_MAX_TOOL_ROUNDS=3

# Feishu Bot Webhook (for contact form notifications)
FEISHU_WEBHOOK_URL=

# Optional secret for external schedulers calling /api/industry-updates/generate-daily
INDUSTRY_CRON_SECRET=
